# Copie este arquivo para .env.local (uso local) e/ou configure as mesmas
# variáveis nas Environment Variables do projeto na Vercel (produção).
# Nunca commite o .env.local de verdade — ele já está no .gitignore.

# Sem essas variáveis, o app roda 100% em modo mock (localStorage), como já
# funciona hoje. Defina NEXT_PUBLIC_DATA_BACKEND=supabase só depois de criar
# o projeto em https://supabase.com e preencher as chaves abaixo.
NEXT_PUBLIC_DATA_BACKEND=mock

# Painel do projeto Supabase → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave de service role — NUNCA prefixar com NEXT_PUBLIC_ (isso a exporia no
# bundle do navegador) e NUNCA commitar o valor real. Nenhum código deste
# repositório a usa hoje (todas as migrations em supabase/ são coladas
# manualmente no SQL Editor do painel) — reservada para uma futura Server
# Action/rota administrativa que precise dela.
SUPABASE_SERVICE_ROLE_KEY=
