# Copie este arquivo para .env.local (uso local) e/ou configure as mesmas
# variáveis nas Environment Variables do projeto na Vercel (produção).
# Nunca commite o .env.local de verdade — ele já está no .gitignore.

# Sem essas variáveis, o app roda 100% em modo mock (localStorage), como já
# funciona hoje. Defina NEXT_PUBLIC_DATA_BACKEND=supabase só depois de criar
# o projeto em https://supabase.com e preencher as chaves abaixo.
NEXT_PUBLIC_DATA_BACKEND=mock

# Painel do projeto Supabase → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# "service_role" — segredo, nunca exponha no navegador. Usado só na rota de
# webhook (app/api/webhooks/lastlink/route.ts), que roda no servidor.
SUPABASE_SERVICE_ROLE_KEY=

# Um valor aleatório forte, definido por você. Vai na URL cadastrada no
# painel da Lastlink: https://SEU-DOMINIO/api/webhooks/lastlink?secret=ESTE_VALOR
LASTLINK_WEBHOOK_SECRET=

# Opcional — o Id do produto na Lastlink (aparece no payload em
# Data.Products[].Id). Se definido, o webhook ignora compras de outros
# produtos vendidos na mesma conta Lastlink.
LASTLINK_PRODUCT_ID=
